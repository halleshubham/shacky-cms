      "id": "c58149cc-6885-4c0c-a00a-f7b0a6297973",
      "name": "Compression"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  const binary = item.binary || {};\n\n  const attachmentKeys = Object.keys(binary)\n    .filter(key => key.startsWith(\"attachment_\"))\n    .sort((a, b) => {\n      const numA = parseInt(a.split(\"_\")[1], 10);\n      const numB = parseInt(b.split(\"_\")[1], 10);\n      return numA - numB;\n    });\n\n  return {\n    json: {\n      ...item.json,\n      attachmentCount: attachmentKeys.length,\n      attachmentNames: attachmentKeys.join(\", \"),\n    },\n    binary: binary, // Preserve binary data\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
