        "jsCode": "// Grab binary from Compression output, JSON from POST Create New Issue\nconst compressedItem = $('Compression').first();\nconst newIssueItem = $('POST Create New Issue').first();\n\nreturn [{\n  json: {\n    ...newIssueItem.json,\n  },\n  binary: {\n    data: compressedItem.binary.data, // the zip binary\n  }\n}];"
      },
